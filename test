#!/bin/bash
# Run flywrite-mode ERT tests in batch mode.

# Stop on errors
set -Eeuo pipefail

# Run from project directory
cd "$(dirname "$0")"

# Byte-compile check
echo "Byte-compile check"
emacs \
  -Q --batch \
  --eval "(setq byte-compile-error-on-warn t)" \
  -f batch-byte-compile \
  flywrite-mode.el
rm -f flywrite-mode.elc

# Run a command and fail if it produces any output on stdout.
check_quiet() {
  output=$("$@" 2>/dev/null)
  if [ -n "$output" ]; then
    echo "$output"
    exit 1
  fi
}

# Lint: elint
echo "Lint: elint"
check_quiet \
  emacs -Q --batch \
    --eval "(require 'elint)" \
    --eval "(elint-file \"flywrite-mode.el\")" \
    --eval "(with-current-buffer \"*Elint*\"
              (princ (buffer-string)))"

# Lint: elisp-lint
# Install from MELPA, disable checks run separately, includes checkdoc
echo "Lint: elisp-lint"
emacs -Q --batch \
  --eval "(require 'package)" \
  --eval "(add-to-list 'package-archives '(\"melpa\" . \"https://melpa.org/packages/\") t)" \
  --eval "(package-initialize)" \
  --eval "(unless (package-installed-p 'elisp-lint)
            (package-refresh-contents)
            (package-install 'elisp-lint))" \
  --eval "(require 'elisp-lint)" \
  -f elisp-lint-files-batch \
  --no-fill-column \
  flywrite-mode.el

# Lint: package-lint (MELPA submission checks)
echo "Lint: package-lint"
emacs -Q --batch \
  --eval "(require 'package)" \
  --eval "(add-to-list 'package-archives '(\"melpa\" . \"https://melpa.org/packages/\") t)" \
  --eval "(package-initialize)" \
  --eval "(unless (package-installed-p 'package-lint)
            (package-refresh-contents)
            (package-install 'package-lint))" \
  --eval "(require 'package-lint)" \
  -f package-lint-batch-and-exit \
  flywrite-mode.el
rm -f flywrite-autoloads.el

# Lint: nesting depth (control-flow forms only, max depth 6)
echo "Lint: nesting depth"
check_quiet \
  emacs -Q --batch \
  -l lint-nesting.el \
  flywrite-mode.el

# Check: README system prompt matches source
echo "Check: README system prompt matches source"
diff <( \
  sed -n '/^(defconst flywrite--academic-prompt$/,/^  "System prompt for academic/{
    /^(defconst/d
    /^  "System prompt for/d
    p
  }' flywrite-mode.el \
  | sed '1s/^  "//; $s/"$//' \
) <( \
  sed -n '/^(setq flywrite-system-prompt$/,/^```$/{
    /^(setq/d
    /^```$/d
    p
  }' README.md \
  | sed '1s/^  "//; $s/")$//' \
  | grep -vF -e '-- ADD, REMOVE, OR EDIT RULES BELOW --' \
)

# Unit tests (filter expected flywrite log messages from stderr)
echo "Unit tests"
emacs -Q --batch \
  -l flywrite-mode.el \
  -l test-flywrite.el \
  -f ert-run-tests-batch-and-exit \
  2>&1 | grep -v '^flywrite:' >&2

# Prompt regression tests (requires API key or cached responses)
echo "Prompt regression tests"
emacs -Q --batch \
 -l flywrite-mode.el \
 -l test-flywrite-prompt.el \
 -f ert-run-tests-batch-and-exit
