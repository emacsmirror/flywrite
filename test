#!/bin/bash
# Run flywrite-mode ERT tests in batch mode.

# Stop on errors
set -Eeuo pipefail

# Run from project directory
cd "$(dirname "$0")"

# Byte-compile check
echo "Byte-compile check"
emacs \
  -Q --batch \
  --eval "(setq byte-compile-error-on-warn t)" \
  -f batch-byte-compile \
  flywrite-mode.el
rm -f flywrite-mode.elc

# Run a command and fail if it produces any output on stdout.
check_quiet() {
  output=$("$@" 2>/dev/null)
  if [ -n "$output" ]; then
    echo "$output"
    exit 1
  fi
}

# Lint: checkdoc
echo "Lint: checkdoc"
check_quiet \
  emacs \
    -Q --batch \
    --eval "(setq checkdoc-verb-check-experimental-flag nil)" \
    --eval "(checkdoc-file \"flywrite-mode.el\")" \
    --eval "(when (get-buffer \"*Warnings*\")
              (with-current-buffer \"*Warnings*\"
                (princ (buffer-string))))"

# Lint: elint
echo "Lint: elint"
check_quiet \
  emacs \
    -Q --batch \
    --eval "(require 'elint)" \
    --eval "(elint-file \"flywrite-mode.el\")" \
    --eval "(with-current-buffer \"*Elint*\"
              (princ (buffer-string)))"

# Lint: elisp-lint (install from MELPA, disable checks run separately)
echo "Lint: elisp-lint"
emacs \
  -Q --batch \
  --eval "(require 'package)" \
  --eval "(add-to-list 'package-archives '(\"melpa\" . \"https://melpa.org/packages/\") t)" \
  --eval "(package-initialize)" \
  --eval "(unless (package-installed-p 'elisp-lint)
            (package-refresh-contents)
            (package-install 'elisp-lint))" \
  --eval "(require 'elisp-lint)" \
  -f elisp-lint-files-batch \
  --no-checkdoc \
  --no-byte-compile \
  --no-indent \
  --no-indent-character \
  --no-fill-column \
  flywrite-mode.el

# Unit tests (filter expected flywrite log messages from stderr)
echo "Unit tests"
emacs \
  -Q --batch \
  -l flywrite-mode.el \
  -l test-flywrite.el \
  -f ert-run-tests-batch-and-exit \
  2>&1 | grep -v '^flywrite:' >&2
