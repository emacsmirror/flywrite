#!/bin/bash
# Run flywrite-mode ERT tests in batch mode.

# Stop on errors, print commands
set -Eeuo pipefail
set -x

# Run from project directory
cd "$(dirname "$0")"

# Run a command and fail if it produces any output on stdout.
check_quiet() {
  output=$("$@" 2>/dev/null)
  if [ -n "$output" ]; then
    echo "$output"
    exit 1
  fi
}

# Lint: checkdoc
check_quiet \
  emacs \
    -Q --batch \
    --eval "(setq checkdoc-verb-check-experimental-flag nil)" \
    --eval "(checkdoc-file \"flywrite-mode.el\")" \
    --eval "(when (get-buffer \"*Warnings*\")
              (with-current-buffer \"*Warnings*\"
                (princ (buffer-string))))"

# Lint: elint
check_quiet \
  emacs \
    -Q --batch \
    --eval "(require 'elint)" \
    --eval "(elint-file \"flywrite-mode.el\")" \
    --eval "(with-current-buffer \"*Elint*\"
              (princ (buffer-string)))"

# Byte-compile check
emacs -Q --batch -f batch-byte-compile flywrite-mode.el
rm -f flywrite-mode.elc

# Unit tests
emacs \
  -Q --batch \
  -l flywrite-mode.el \
  -l test-flywrite.el \
  -f ert-run-tests-batch-and-exit
